<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>com.apple.security.app-sandbox</key>
  <true/>
  <key>com.apple.security.network.client</key>
  <true/>
  <key>com.apple.security.temporary-exception.files.home-relative-path.read-only</key>
  <array>
    <string>/.claude/projects/</string>
    <string>/Library/Application Support/Claude/claude-code-sessions/</string>
    <string>/Library/Application Support/Claude/local-agent-mode-sessions/</string>
    <string>/.codex/sessions/</string>
    <string>/.local/share/opencode/sessions/</string>
    <string>/.config/opencode/sessions/</string>
  </array>
</dict>
</plist>
